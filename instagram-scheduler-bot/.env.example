# =============================================================================
# Instagram Scheduler Bot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- App ---
PORT=3000
NODE_ENV=development

# --- Encryption (MUST be exactly 32 characters for AES-256) ---
ENCRYPTION_KEY=

# --- Cron Job Auth & Dashboard Admin ---
CRON_SECRET=
ADMIN_PASSWORD=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Slack ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# --- Cloudflare R2 ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_PUBLIC_DEV_URL=

# --- Meta / Instagram ---
META_GRAPH_API_VERSION=v20.0
